---
import astroLogo from '../assets/astro.svg';
import background from '../assets/background.svg';
---

<section class="py-16 bg-gray-50">
    <h2 class="text-2xl font-bold text-center mb-10">¿Por qué elegirnos?</h2>
  
    <div class="grid md:grid-cols-3 gap-6 max-w-6xl mx-auto">
  
      <div class="p-4 bg-white rounded shadow">
        <h3 class="font-semibold">Rápido</h3>
        <p>Recogida inmediata en el aeropuerto</p>
      </div>
  
      <div class="p-4 bg-white rounded shadow">
        <h3 class="font-semibold">Seguro</h3>
        <p>Conductores verificados</p>
      </div>
  
      <div class="p-4 bg-white rounded shadow">
        <h3 class="font-semibold">Económico</h3>
        <p>Precios transparentes</p>
      </div>
  
    </div>
</section>