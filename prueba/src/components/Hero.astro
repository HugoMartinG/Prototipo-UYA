---
import astroLogo from '../assets/astro.svg';
import background from '../assets/background.svg';
---

<section class="bg-gray-50 py-16 text-center">
    <h1 class="text-4xl font-bold text-gray-900">
      Reserva tu taxi desde el aeropuerto
    </h1>
  
    <p class="mt-4 text-lg text-gray-600">
      Traslados rápidos desde el Aeropuerto de Tenerife Sur a cualquier punto de la isla
    </p>
  
    <a href="/reserva"
       class="inline-block mt-6 bg-blue-700 text-white px-6 py-3 rounded-lg hover:bg-blue-800 focus:ring-4 focus:ring-blue-300">
       Reservar ahora
    </a>
</section>